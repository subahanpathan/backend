{
  "version": 2,
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_KEY": "@supabase_key",
    "SUPABASE_SERVICE_KEY": "@supabase_service_key",
    "JWT_SECRET": "@jwt_secret",
    "JWT_EXPIRE": "7d",
    "NODE_ENV": "production",
    "PORT": "3001",
    "CORS_ORIGIN": "@cors_origin",
    "MAX_FILE_SIZE": "5242880",
    "UPLOAD_DIR": "/tmp/uploads/"
  },
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "public": false,
  "github": {
    "enabled": true,
    "silent": true
  }
}
